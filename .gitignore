# ------------------------------
# 0. 自定义产物
# ------------------------------
.idea/
out/

# ------------------------------
# 1. Java 编译产物
# ------------------------------
# 所有层级的 class 文件
**/*.class

# 字节码缓存
**/*.ctxt

# 打包文件（注意：如果需要提交第三方依赖 jar，请注释掉这行）
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# JVM 崩溃日志
hs_err_pid*
replay_pid*
hs_err_*.log
replay_*.log

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# ------------------------------
# 2. Maven 构建工具
# ------------------------------
# 所有层级的 target 目录（多模块项目适用）
**/target/
target/

# Maven 包装器（保留 wrapper 以确保团队使用统一版本）
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# Maven 本地仓库缓存
.m2/repository/
.m2/settings.xml

# Maven 生成的站点文档
**/target/site/
**/target/apidocs/

# ------------------------------
# 3. Gradle 构建工具
# ------------------------------
# 所有层级的 build 目录
**/build/
build/

# Gradle 缓存
.gradle/
**/.gradle/

# Gradle 包装器（保留 wrapper 以确保团队使用统一版本）
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Gradle 生成的日志
gradle-app.setting
*.gradle.kts.bak

# ------------------------------
# 4. Ant 构建工具
# ------------------------------
# Ant 输出目录
ant_build/
dist/
lib/

# Ant 配置备份
build.xml.bak

# ------------------------------
# 5. Ivy 依赖管理
# ------------------------------
.ivy/
.ivyrepo/
ivy-*.xml

# ------------------------------
# 6. 测试相关
# ------------------------------
# JUnit / TestNG 测试报告
**/test-output/
**/surefire-reports/
**/failsafe-reports/

# 测试覆盖率报告 (JaCoCo, Cobertura)
**/jacoco.exec
**/jacoco/
**/coverage/
**/cobertura/

# 测试临时文件
**/test-tmp/
**/test-data/

# ------------------------------
# 7. 文档生成
# ------------------------------
# Javadoc
**/apidocs/
**/javadoc/

# Asciidoctor
**/build/docs/
**/asciidoc/
*.asc
!README.asc
!CHANGELOG.asc

# Markdown 生成的 HTML
*.html
*.pdf

# ------------------------------
# 8. IntelliJ IDEA / JetBrains 系列 IDE
# ------------------------------
# 项目配置目录
.idea/
**/.idea/

# 模块文件
*.iml
*.ipr
*.iws

# 编译输出目录
out/
**/out/

# 运行时配置（如果团队需要共享运行配置，请注释掉这行）
.idea/runConfigurations/

# 代码样式配置（如果团队需要统一代码样式，请注释掉这行）
.idea/codeStyles/

# 本地历史记录
.idea/localHistory/

# 缓存文件
.idea/caches/
.idea/shelf/


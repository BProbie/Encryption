# ------------------------------
# 项目配置文件
.project
.classpath
.settings/
**/.settings/

# 编译输出目录
bin/
**/bin/

# Eclipse 工作区
.metadata/
.recommenders/

# Eclipse 插件配置
.springBeans
.factorypath

